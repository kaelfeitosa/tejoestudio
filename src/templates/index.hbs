<!DOCTYPE html>
<html lang="{{lang}}">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{index.title}}</title>
  <link rel="icon" type="image/png" href="{{{base_path}}}images/tejo_icon.png">
  <meta name="description" content="{{index.description}}">
  <meta name="keywords" content="{{index.keywords}}">
  <link rel="canonical" href="{{site_url}}{{canonical_path}}">
  <link rel="alternate" hreflang="{{lang}}" href="{{site_url}}{{canonical_path}}">
  {{#each other_langs}}
  <link rel="alternate" hreflang="{{code}}" href="{{../site_url}}{{canonical_path}}">
  {{/each}}
  <meta name="author" content="Tejo Estúdio">

  <!-- Open Graph -->
  <meta property="og:title" content="{{index.title}}">
  <meta property="og:description" content="{{index.description}}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{site_url}}{{canonical_path}}">
  <meta property="og:image" content="{{site_url}}press-kit/vem-exu/02_branding/store/steam_key_art.png">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{index.title}}">
  <meta name="twitter:description" content="{{index.description}}">
  <meta name="twitter:image" content="{{site_url}}press-kit/vem-exu/02_branding/store/steam_key_art.png">

  <!-- Novos Estilos Base do Tejo Estúdio -->
  <link rel="stylesheet" href="{{{base_path}}}css/tejo-base.css">
  <link rel="stylesheet" href="{{{base_path}}}css/tejo-brands.css">
  {{> partials/lang_redirect}}

  <!-- Schema.org / JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tejo Estúdio",
    "url": "{{site_url}}",
    "logo": "{{site_url}}images/tejo_logo_black.png",
    "description": {{{json index.footer}}},
    "sameAs": [
      "https://x.com/tejoestudio",
      "https://instagram.com/tejoestudio",
      "https://threads.net/@tejoestudio",
      "https://tejoestudio.bsky.social"
    ]
  }
  </script>
</head>

<body class="tejo-bg-vem-exu">
  <div class="tejo-lang-switcher-container">
    {{#each other_langs}}
    <a href="{{{link}}}" class="tejo-lang-switcher" aria-label="{{aria}}" onclick="if(window.tejoSetLang){ window.tejoSetLang('{{code}}'); return false; }">
      {{label}}
    </a>
    {{/each}}
  </div>
  <div class="tejo-corner-kite" aria-hidden="true">
    <img src="{{{base_path}}}images/hero_kite.png" alt="Pipa">
  </div>
  <div class="tejo-corner-exu" aria-hidden="true">
    <img src="{{{base_path}}}images/hero_exu.png" alt="Exu">
  </div>

  <main class="tejo-linktree-container">
    <div id="tejo-video-logo" class="tejo-video-logo-trigger tejo-mb-2" 
      onclick="tejoPlayTrailer()" 
      onkeydown="if(event.key === 'Enter' || event.key === ' '){ tejoPlayTrailer(); event.preventDefault(); }"
      role="button" 
      tabindex="0" 
      aria-label="{{index.trailer_aria}}">
      <figure class="tejo-video-frame">
        <img src="{{{base_path}}}press-kit/vem-exu/02_branding/logos/vem_exu_logo_black.png" 
          alt="Vem Exu Logo" class="tejo-main-logo">
        <div class="tejo-play-overlay" aria-hidden="true"><span>▶</span></div>
      </figure>
    </div>

    <script>
      function tejoPlayTrailer() {
        const container = document.getElementById('tejo-video-logo');
        container.innerHTML = `
          <figure class="tejo-video-frame">
            <iframe src="https://www.youtube.com/embed/{{index.trailer_id}}?autoplay=1" 
              title="Vem, Exu - Trailer" frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen></iframe>
          </figure>
        `;
        container.classList.add('is-playing');
        container.onclick = null;
        container.onkeydown = null;
        container.removeAttribute('role');
        container.removeAttribute('tabindex');
        container.removeAttribute('aria-label');
      }
    </script>
    <h1 class="tejo-visually-hidden">{{index.title}}</h1>
    <section>
    <h2 class="tejo-hero-subtitle tejo-mt-2 tejo-mb-2"><strong>{{index.vem_exu_subtitle}}</strong></h2>

      <nav aria-label="{{index.aria_main_links}}">
        <a class="tejo-link-btn tejo-brand-steam"
          href="https://store.steampowered.com/app/4605020/Vem_Exu/" target="_blank" rel="noopener">
          <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/steam.svg" alt="">
          {{{index.steam_wishlist_btn}}}
        </a>

        <a class="tejo-link-btn tejo-brand-white"
          href="https://store.steampowered.com/app/4605020/Vem_Exu/" target="_blank" rel="noopener">
          <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/steam.svg" alt="">
          {{{index.steam_demo_btn}}}
        </a>

        <a class="tejo-link-btn tejo-brand-playstore"
          href="https://play.google.com/store/apps/details?id=com.tejoestudio.exu" target="_blank" rel="noopener">
          <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/google-play.svg" alt="">
          {{{index.playstore_btn}}}
        </a>
      </nav>

      <div class="tejo-mt-2">
        <p class="tejo-narrative-text"><strong>{{{index.vem_exu_desc}}}</strong></p>
      </div>

      <p class="tejo-mt-2 tejo-credits-text">
        <small>{{{index.vem_exu_desc2}}}</small>
      </p>



    </section>

    <nav aria-label="{{index.aria_nav_links}}" class="tejo-mt-2">
      <a class="tejo-link-btn tejo-brand-instagram" href="https://www.instagram.com/tejoestudio" target="_blank"
        rel="noopener">
        <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/instagram.svg" alt="">
        {{index.instagram}}
      </a>

      <a class="tejo-link-btn tejo-brand-press" href="{{{language_path}}}press-kit/vem-exu/index.html">
        <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/generic-blog.svg" alt="">
        {{index.presskit}}
      </a>

      <a class="tejo-link-btn tejo-brand-amazon"
        href="https://www.amazon.com.br/Contos-Exu-Rafael-Semino-ebook/dp/B0D192M6VJ" target="_blank" rel="noopener">
        <img class="icon" aria-hidden="true" src="{{{base_path}}}images/icons/amazon.svg" alt="">
        {{index.amazon}}
      </a>
    </nav>

    <footer class="tejo-footer">
      <img src="{{{base_path}}}images/tejo_logo_black.png" alt="Tejo Estúdio" class="tejo-footer-logo">
      <div class="tejo-footer-content">
        <p>
          {{index.footer}}
          <span class="tejo-footer-meta">{{{index.footer_meta}}}</span>
          | <a href="{{{language_path}}}portfolio.html" style="color: inherit; opacity: 0.8;">{{index.portfolio}}</a>
          | <a href="https://www.threads.net/@tejoestudio" target="_blank" rel="noopener" style="color: inherit; opacity: 0.8;">{{index.threads}}</a>
          | <a href="{{{base_path}}}privacy.html" style="color: inherit; opacity: 0.8;">{{index.privacy}}</a>
        </p>
      </div>
    </footer>
  </main>
</body>

</html>
