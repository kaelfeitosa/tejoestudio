<!DOCTYPE html>
<html lang="{{lang}}">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{portfolio.title}}</title>
  <link rel="icon" type="image/png" href="{{{base_path}}}images/tejo_icon.png">
  <meta name="description" content="{{portfolio.meta_description}}">

  <!-- Estilos Base do Tejo Estúdio -->
  <link rel="stylesheet" href="{{{base_path}}}css/tejo-base.css">
  <link rel="stylesheet" href="{{{base_path}}}css/tejo-portfolio.css">
  {{> partials/lang_redirect}}
</head>

<body>
  <div class="tejo-lang-switcher-container">
    {{#each other_langs}}
    <a href="{{{link}}}" class="tejo-lang-switcher" aria-label="{{aria}}" onclick="if(window.tejoSetLang){ window.tejoSetLang('{{code}}'); return false; }">
      {{label}}
    </a>
    {{/each}}
  </div>

  <!-- Barra de Navegação Superior Semântica -->
  <nav class="nav-fixed">
    <div class="nav-inner">
      <div class="tejo-brand-logo">
        <a href="#home">MF.</a>
      </div>
      <div class="portfolio-nav-links">
        <a href="{{{language_path}}}index.html">{{portfolio.nav_home}}</a>
        <a href="#poetica">{{portfolio.nav_poetics}}</a>
        <a href="#projetos">{{portfolio.nav_projects}}</a>
        <a href="#circulacao">{{portfolio.nav_circulation}}</a>
        <a href="#sobre">{{portfolio.nav_about}}</a>
        <a href="#contato">{{portfolio.nav_contact}}</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header id="home" class="portfolio-shell portfolio-hero">
    <h1>MICHAEL<br>FEITOSA</h1>
    <div class="portfolio-hero-divider"></div>
    <p class="portfolio-hero-role">
      {{portfolio.hero_role}}
    </p>
    <p class="portfolio-hero-location">
      {{portfolio.hero_location}}
    </p>

    <div class="portfolio-hero-actions">
      <a href="#projetos" class="tejo-btn primary">{{portfolio.hero_view_projects}} &rarr;</a>
      <a href="{{{base_path}}}docs/portfolio_michael_feitosa.pdf" target="_blank" rel="noopener" class="tejo-btn">
        <img src="{{{base_path}}}images/icons/download.svg" alt="" style="width: 1.25rem; height: 1.25rem; display: inline; vertical-align: middle; margin-right: 0.5rem;">
        {{{index.download_pdf}}}
      </a>
      <a href="https://kaelfeitosa.itch.io" target="_blank" rel="noopener" class="tejo-btn">Itch.io</a>
    </div>
  </header>

  <!-- Main Content Wrapper -->
  <main>
    
    <!-- Poética -->
    <section id="poetica" class="portfolio-dark-section portfolio-section">
      <div class="portfolio-shell portfolio-poetics-container">
        <h2 class="portfolio-poetics-title">
          {{portfolio.poetics_title}}
        </h2>
        <blockquote class="portfolio-poetics-quote">
          {{portfolio.poetics_quote}}
        </blockquote>
        <div class="portfolio-poetics-grid">
          <p>
            {{{portfolio.poetics_p1}}}
          </p>
          <p>
            {{{portfolio.poetics_p2}}}
          </p>
        </div>
      </div>
    </section>

    <!-- Obras e Projetos Principais -->
    <section id="projetos" class="portfolio-shell portfolio-section">
      <header class="portfolio-projects-header">
        <h2>{{portfolio.projects_title}}</h2>
        <span class="portfolio-projects-subtitle">{{portfolio.projects_subtitle}}</span>
      </header>

      <div class="portfolio-projects-list">
        <!-- Vem Exu -->
        <article class="project-article">
          <div class="portfolio-col-span-5">
            <figure class="aspect-3-4">
              <img src="{{{base_path}}}images/portfolio/vem_exu.png" alt="{{portfolio.vem_exu_title}}" class="object-cover tejo-grayscale">
            </figure>
          </div>
          <div class="portfolio-col-span-7 project-details-column">
            <h3>{{portfolio.vem_exu_title}}</h3>
            <div class="project-tags">
              <span class="project-tag">{{portfolio.vem_exu_tag1}}</span>
              <span class="project-tag">{{portfolio.vem_exu_tag2}}</span>
            </div>
            <p>
              {{{portfolio.vem_exu_desc}}}
            </p>
            
            <ul class="project-bullets">
              <li>{{{portfolio.vem_exu_poetics}}}</li>
              <li>{{{portfolio.vem_exu_tech}}}</li>
              <li>{{{portfolio.vem_exu_team}}} {{{portfolio.vem_exu_team_desc}}}</li>
              <li>{{{portfolio.vem_exu_highlight}}}</li>
            </ul>

            <!-- Prova Social (Aspas do Press Kit) -->
            <blockquote class="project-quote">
              {{{presskit.quote_1}}}
              <cite>{{{presskit.quote_1_cite}}}</cite>
            </blockquote>

            <div class="project-action-btn">
              <a href="https://store.steampowered.com/app/4605020/Vem_Exu/" target="_blank" rel="noopener" class="tejo-btn primary">{{portfolio.vem_exu_play_demo}} &nearrow;</a>
            </div>
          </div>
        </article>

        <!-- RAIAR -->
        <article class="project-article">
          <div class="portfolio-col-span-7 portfolio-order-2">
             <figure class="aspect-video" style="background: #171717; display: flex; align-items: center; justify-content: center; margin: 0; box-shadow: var(--shadow-hard);">
                <span style="color: #404040; font-family: var(--font-mono); border: 1px dashed #404040; padding: 1rem;">{{portfolio.raiar_image_soon}}</span>
             </figure>
          </div>
          <div class="portfolio-col-span-5 portfolio-order-1 project-details-column">
            <h3>{{portfolio.raiar_title}}</h3>
            <div class="project-tags">
              <span class="project-tag">{{portfolio.raiar_tag1}}</span>
              <span class="project-tag">{{portfolio.raiar_tag2}}</span>
            </div>
            <p>
              {{{portfolio.raiar_desc}}}
            </p>
            <ul class="project-bullets">
              <li>{{{portfolio.raiar_poetics}}}</li>
              <li>{{{portfolio.raiar_tech}}}</li>
              <li>{{{portfolio.raiar_highlight}}}</li>
            </ul>
          </div>
        </article>
      </div>

      <!-- Outras Obras -->
      <div class="portfolio-other-works">
        <h4>{{portfolio.other_works_title}}</h4>
        <div class="portfolio-other-grid">
          <article>
            <a href="https://youtu.be/F-0FELizya8" target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
              <figure style="border: 2px solid #000; box-shadow: 4px 4px 0px #000; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; overflow: hidden;" onmouseover="this.style.transform='translate(-2px, -2px)'; this.style.boxShadow='6px 6px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='4px 4px 0px #000';">
                <img src="{{{base_path}}}images/portfolio/maria_da_lua.png" alt="{{portfolio.maria_lua_title}}" class="object-cover tejo-grayscale" style="transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
              </figure>
            </a>
            <h5 style="margin-top: 1rem; font-weight: 900; text-transform: uppercase;">{{portfolio.maria_lua_title}}</h5>
            <p>{{{portfolio.maria_lua_desc}}}</p>
            <p style="font-size: 0.8rem; color: #737373; margin-top: 0.5rem; line-height: 1.4;">{{{portfolio.maria_lua_team}}}</p>
            <a href="https://youtu.be/F-0FELizya8" target="_blank" rel="noopener" class="portfolio-work-link" style="color: #000; font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase; font-weight: 700; text-decoration: underline; margin-top: 0.5rem; display: inline-block;">YouTube &nearrow;</a>
          </article>
          <article>
            <a href="https://play.google.com/store/apps/details?id=com.tejoestudio.hamilton" target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
              <figure style="border: 2px solid #000; box-shadow: 4px 4px 0px #000; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; overflow: hidden;" onmouseover="this.style.transform='translate(-2px, -2px)'; this.style.boxShadow='6px 6px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='4px 4px 0px #000';">
                <img src="{{{base_path}}}images/portfolio/hamilton.png" alt="{{portfolio.hamilton_title}}" class="object-cover tejo-grayscale" style="transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
              </figure>
            </a>
            <h5 style="margin-top: 1rem; font-weight: 900; text-transform: uppercase;">{{portfolio.hamilton_title}}</h5>
            <p>{{{portfolio.hamilton_desc}}}</p>
            <p style="font-size: 0.8rem; color: #737373; margin-top: 0.5rem; line-height: 1.4;">{{{portfolio.hamilton_team}}}</p>
            <a href="https://play.google.com/store/apps/details?id=com.tejoestudio.hamilton" target="_blank" rel="noopener" class="portfolio-work-link" style="color: #000; font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase; font-weight: 700; text-decoration: underline; margin-top: 0.5rem; display: inline-block;">Google Play &nearrow;</a>
          </article>
          <article>
            <a href="https://kaelfeitosa.itch.io/the-sias-oath" target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
              <figure style="border: 2px solid #000; box-shadow: 4px 4px 0px #000; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; overflow: hidden;" onmouseover="this.style.transform='translate(-2px, -2px)'; this.style.boxShadow='6px 6px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='4px 4px 0px #000';">
                <img src="{{{base_path}}}images/portfolio/sina_de_sia.png" alt="{{portfolio.sina_sia_title}}" class="object-cover tejo-grayscale" style="transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)';" onmouseout="this.style.transform='scale(1)';">
              </figure>
            </a>
            <h5 style="margin-top: 1rem; font-weight: 900; text-transform: uppercase;">{{portfolio.sina_sia_title}}</h5>
            <p>{{{portfolio.sina_sia_desc}}}</p>
            <p style="font-size: 0.8rem; color: #737373; margin-top: 0.5rem; line-height: 1.4;">{{{portfolio.sina_sia_team}}}</p>
            <a href="https://kaelfeitosa.itch.io/the-sias-oath" target="_blank" rel="noopener" class="portfolio-work-link" style="color: #000; font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase; font-weight: 700; text-decoration: underline; margin-top: 0.5rem; display: inline-block;">Itch.io &nearrow;</a>
          </article>
        </div>
      </div>
    </section>

    <!-- Exposições e Circulação -->
    <section id="circulacao" class="portfolio-dark-section portfolio-section">
      <div class="portfolio-shell">
        <h3 class="portfolio-circulation-title">
          ✦ {{portfolio.circulation_title}}
        </h3>
        <p class="portfolio-circulation-desc">
          {{portfolio.circulation_desc}}
        </p>
        
        <div class="portfolio-circulation-grid">
          <!-- SANA -->
          <article class="portfolio-event-card">
            <div>
              <header class="portfolio-event-header">
                <span class="portfolio-event-tag">{{portfolio.event_sana_tag}}</span>
                <strong class="portfolio-event-title">{{portfolio.event_sana_title}}</strong>
              </header>
              <p class="portfolio-event-desc">
                {{portfolio.event_sana_desc}}
              </p>
            </div>
            <div class="portfolio-event-gallery">
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/sana_2026_1_01.jpeg" alt="{{{presskit.alt_event_sana_01}}}" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/sana_2026_1_02.jpeg" alt="{{{presskit.alt_event_sana_02}}}" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/sana_2026_1_03.jpeg" alt="Sana 3" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
            </div>
          </article>

          <!-- Feira do Conhecimento -->
          <article class="portfolio-event-card">
            <div>
              <header class="portfolio-event-header">
                <span class="portfolio-event-tag">{{portfolio.event_feira_tag}}</span>
                <strong class="portfolio-event-title">{{portfolio.event_feira_title}}</strong>
              </header>
              <p class="portfolio-event-desc">
                {{portfolio.event_feira_desc}}
              </p>
            </div>
            <div class="portfolio-event-gallery">
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/feira_do_conhecimento_01.jpeg" alt="{{{presskit.alt_event_feira_01}}}" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/feira_do_conhecimento_02.jpeg" alt="{{{presskit.alt_event_feira_02}}}" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/feira_do_conhecimento_03.jpeg" alt="Feira 3" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
            </div>
          </article>

          <!-- Escolas -->
          <article class="portfolio-event-card">
            <div>
              <header class="portfolio-event-header">
                <span class="portfolio-event-tag">{{portfolio.event_escolas_tag}}</span>
                <strong class="portfolio-event-title">{{portfolio.event_escolas_title}}</strong>
              </header>
              <p class="portfolio-event-desc">
                {{portfolio.event_escolas_desc}}
              </p>
            </div>
            <div class="portfolio-event-gallery">
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/escola_torres_de_melo_01.jpg" alt="{{{presskit.alt_event_escola_01}}}" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/nac_passare_01.jpg" alt="NAC Passaré 1" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
              <figure class="portfolio-gallery-item">
                <img src="{{{base_path}}}press-kit/vem-exu/03_community/events/nac_passare_02.jpg" alt="NAC Passaré 2" class="tejo-grayscale" onclick="window.open(this.src)">
              </figure>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Pesquisa e Temas & Processos e Tecnologias -->
    <section class="portfolio-research portfolio-section">
      <div class="portfolio-shell portfolio-research-grid">
        <!-- Pesquisa e Temas -->
        <div>
          <h3>
            <span class="portfolio-square-bullet"></span>
            {{portfolio.research_title}}
          </h3>
          <ul class="portfolio-mono-list">
            <li>{{portfolio.research_item1}}</li>
            <li>{{portfolio.research_item2}}</li>
            <li>{{portfolio.research_item3}}</li>
            <li>{{portfolio.research_item4}}</li>
            <li>{{portfolio.research_item5}}</li>
          </ul>
        </div>
        
        <!-- Processos e Tecnologias -->
        <div>
          <h3>
            <span class="portfolio-square-bullet portfolio-bullet-asterisk"></span>
            {{portfolio.process_title}}
          </h3>
          <ul class="portfolio-mono-list">
            <li>{{portfolio.process_item1}}</li>
            <li>{{portfolio.process_item2}}</li>
            <li>{{portfolio.process_item3}}</li>
            <li>{{portfolio.process_item4}}</li>
            <li>{{portfolio.process_item5}}</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Sobre Mim -->
    <section id="sobre" class="portfolio-about portfolio-section">
      <div class="portfolio-shell">
        <article class="portfolio-about-card">
          <h2>{{portfolio.about_title}}</h2>
          
          <div class="portfolio-about-content">
            <!-- Foto -->
            <figure class="portfolio-about-avatar">
              <img src="{{{base_path}}}images/michael_feitosa.png" alt="Michael Feitosa" class="tejo-grayscale">
            </figure>
            
            <!-- Texto -->
            <div class="portfolio-about-text">
              <p>{{{portfolio.about_p1}}}</p>
              <p>{{{portfolio.about_p2}}}</p>
            </div>
          </div>

          <!-- Contatos do Sobre -->
          <footer class="portfolio-about-footer">
            <address id="contato" class="portfolio-contact-block">
              <h3>{{portfolio.nav_contact}}</h3>
              <a href="mailto:michaelrfeitosa@gmail.com">
                ✉ michaelrfeitosa@gmail.com
              </a>
            </address>

            <div class="portfolio-docs-block">
              <h3>{{portfolio.about_docs}}</h3>
              <a href="{{{base_path}}}docs/curriculo_michael_feitosa.pdf" download class="portfolio-download-btn">
                {{portfolio.about_resume}}
              </a>
            </div>
          </footer>
        </article>
      </div>
    </section>

  </main>

  <footer class="tejo-footer">
    <img src="{{{base_path}}}images/tejo_logo_black.png" alt="Tejo Estúdio" class="tejo-footer-logo">
    <div class="tejo-footer-content">
      <p>
        {{index.footer}}<br>
        <span class="tejo-footer-meta">{{{index.footer_meta}}}</span>
        | <a href="{{{language_path}}}index.html">{{portfolio.nav_home}}</a>
        | <a href="{{{language_path}}}privacy.html">{{{index.privacy}}}</a>
      </p>
      {{> partials/footer_social}}
    </div>
  </footer>
</body>

</html>
